---
interface Props {
	title: string;
	description: string;
	label: string;
	tone: 'amber' | 'red' | 'blue' | 'green';
	href: string;
}

const { title, description, label, tone, href } = Astro.props;
---

<a class:list={['category-card', `tone-${tone}`]} href={href}>
	<div class="category-art" aria-hidden="true">
		<span></span><span></span><span></span>
	</div>
	<div class="category-copy">
		<p class="eyebrow">{label}</p>
		<h3>{title}</h3>
		<p>{description}</p>
		<span class="category-link">Смотреть подборки <span aria-hidden="true">→</span></span>
	</div>
</a>
