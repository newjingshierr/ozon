---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Страница не найдена" description="Запрошенная страница не найдена." noindex>
	<section class="not-found shell">
		<p class="display-number">404</p>
		<h1>Этой страницы пока нет</h1>
		<p>Возможно, ссылка устарела или адрес введён с ошибкой.</p>
		<a class="button button-primary" href="/">На главную</a>
	</section>
</BaseLayout>
