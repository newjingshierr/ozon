---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const products = (await getCollection('products', ({ data }) => !data.draft))
	.sort((a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime());
const description = 'Каталог тематических флагов, постеров и картин ArtBox World с переходом к товарам на Ozon.';
---

<BaseLayout title="Каталог флагов, постеров и картин" {description}>
	<section class="page-hero shell">
		<p class="eyebrow">ArtBox World</p>
		<h1>Каталог</h1>
		<p class="lead">Тематические идеи для стен — по музыке, спорту, мифологии и искусству.</p>
	</section>
	<section class="section shell">
		{products.length ? (
			<>
				<div class="catalog-filters" aria-label="Фильтр каталога">
					<a href="/catalog/" data-filter="all">Все</a>
					<a href="/catalog/?category=rock" data-filter="rock">Рок и музыка</a>
					<a href="/catalog/?category=sport" data-filter="sport">Спорт</a>
					<a href="/catalog/?category=mythology" data-filter="mythology">Мифология</a>
					<a href="/catalog/?category=art" data-filter="art">Искусство</a>
				</div>
			<div class="product-grid" id="catalog-grid">
				{products.map((product) => (
					<a class="product-card" data-category={product.data.category} href={`/catalog/${product.id}/`}>
						<img src={product.data.image} alt={product.data.imageAlt} loading="lazy" />
						<div><h2>{product.data.title}</h2><p>{product.data.description}</p></div>
					</a>
				))}
			</div>
				<p class="filter-empty" id="filter-empty" hidden>В этой теме пока нет опубликованных подборок.</p>
			</>
		) : (
			<div class="empty-state">
				<p class="eyebrow">Скоро</p>
				<h2>Первая коллекция готовится к публикации</h2>
				<p>Мы добавляем изображения и проверяем ссылки на товары Ozon. Загляните немного позже.</p>
				<a class="button button-secondary" href="/">Вернуться на главную</a>
			</div>
		)}
	</section>
	<script is:inline>
		(function () {
			var allowed = ['rock', 'sport', 'mythology', 'art'];
			var selected = new URLSearchParams(window.location.search).get('category');
			var category = allowed.indexOf(selected) >= 0 ? selected : 'all';
			var cards = document.querySelectorAll('#catalog-grid [data-category]');
			var visible = 0;
			cards.forEach(function (card) {
				var show = category === 'all' || card.getAttribute('data-category') === category;
				card.hidden = !show;
				if (show) visible += 1;
			});
			document.querySelectorAll('.catalog-filters [data-filter]').forEach(function (link) {
				if (link.getAttribute('data-filter') === category) link.setAttribute('aria-current', 'page');
			});
			var empty = document.getElementById('filter-empty');
			if (empty) empty.hidden = visible !== 0;
		})();
	</script>
</BaseLayout>
